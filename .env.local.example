# ─── GitHub App ───────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
GITHUB_APP_ID=                          # e.g. 123456
GITHUB_APP_NAME=designmd               # slug shown in marketplace
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=                  # random string, set same in App settings
GITHUB_CLIENT_ID=                       # OAuth App client ID (from App settings)
GITHUB_CLIENT_SECRET=                   # OAuth App client secret

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ─── Anthropic (for editor) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/designmd/installations/new
